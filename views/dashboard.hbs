<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ollama Gateway Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --accent: #38bdf8;
            --request: #3b82f6;
            --response: #10b981;
            --error: #ef4444;
            --border: #334155;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
            background-color: var(--bg);
        }

        body {
            color: var(--text);
            font-family: 'Inter', -apple-system, sans-serif;
            line-height: 1.4;
            display: flex;
            flex-direction: column;
            font-size: 13px;
        }

        header {
            width: 100%;
            padding: 0.75rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(12px);
            z-index: 50;
            flex-shrink: 0;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo span { color: var(--accent); }

        .status {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.75rem;
            font-weight: 500;
            padding: 0.2rem 0.6rem;
            background: rgba(16, 185, 129, 0.1);
            color: var(--response);
            border-radius: 9999px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-dot {
            width: 6px;
            height: 6px;
            background-color: var(--response);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--response);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); opacity: 0.8; }
            50% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.8; }
        }

        main { 
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 1rem 1.5rem; 
            max-width: 1200px; 
            margin: 0 auto; 
            width: 100%;
            overflow: hidden;
        }

        .scroll-area {
            flex: 1;
            overflow-y: auto;
            margin-top: 0.5rem;
        }

        .log-container {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            padding-bottom: 2rem;
            width: 100%;
        }

        .log-entry {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .log-header {
            padding: 0.75rem 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            user-select: none;
        }

        .log-header:hover { background: rgba(255, 255, 255, 0.02); }

        .log-info { display: flex; align-items: center; gap: 0.75rem; }

        .badge {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 0.15rem 0.4rem;
            border-radius: 4px;
        }

        .badge-pending { background: rgba(59, 130, 246, 0.15); color: var(--request); }
        .badge-streaming { 
            background: rgba(168, 85, 247, 0.15); 
            color: #a855f7; 
            animation: streamingPulse 2s infinite;
        }
        .badge-completed { background: rgba(16, 185, 129, 0.15); color: var(--response); }
        .badge-failed { background: rgba(239, 68, 68, 0.15); color: var(--error); }

        @keyframes streamingPulse {
            0% { opacity: 0.8; }
            50% { opacity: 1; transform: scale(1.05); }
            100% { opacity: 0.8; }
        }

        .method { font-family: 'JetBrains Mono', monospace; font-weight: 600; color: var(--text-muted); font-size: 0.8rem; }
        .path { font-family: 'JetBrains Mono', monospace; font-weight: 500; font-size: 0.8rem; }
        .device-tag { color: var(--accent); font-weight: 600; font-size: 0.8rem; }
        .id { color: var(--text-muted); font-size: 0.75rem; opacity: 0.6; }
        .time { color: var(--text-muted); font-size: 0.75rem; }

        .log-details {
            padding: 0 1rem 1rem 1rem;
            border-top: 1px solid var(--border);
            display: none;
        }

        .log-entry.expanded .log-details { display: block; }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .detail-item label {
            display: block;
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }

        .detail-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            background: #0d1117;
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid var(--border);
            max-height: 500px;
            overflow: auto;
            display: block;
            white-space: pre-wrap; /* Better for the simple text rendering in dashboard */
            word-break: break-all;
        }

        .stats-summary {
            display: flex;
            gap: 1.25rem;
            margin-bottom: 1rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 500;
            background: rgba(30, 41, 59, 0.3);
            padding: 0.5rem 1rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            width: fit-content;
            flex-shrink: 0;
        }

        .stats-summary span { color: var(--accent); font-weight: 700; margin-left: 0.2rem; }

        /* Custom scrollbar for better visibility while staying sleek */
        ::-webkit-scrollbar { display: none; }
        * { -ms-overflow-style: none; scrollbar-width: none; }

        /* Responsiveness */
        @media (max-width: 900px) {
            main { padding: 0.75rem; width: 100%; max-width: 100vw; }
            .stats-summary { 
                flex-direction: column; 
                gap: 0.5rem; 
                width: 100%;
                padding: 1rem;
                margin-bottom: 1rem;
            }
            .scroll-area {
                padding: 0;
                margin-top: 0.5rem;
                width: 100%;
            }
            .log-entry { width: 100%; }
            .log-header { 
                width: 100%;
                padding: 0.75rem;
                flex-direction: column; 
                align-items: flex-start; 
                gap: 0.6rem; 
            }
            .log-info { 
                flex-wrap: wrap; 
                gap: 0.5rem; 
                width: 100%;
                word-break: break-all;
            }
            .path { word-break: break-all; width: 100%; }
            .time { 
                width: 100%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-top: 1px solid var(--border);
                padding-top: 0.6rem;
                margin-top: 0.2rem;
            }
            .detail-value { padding: 0.75rem; font-size: 0.75rem; }
        }

        @media (max-width: 480px) {
            header { padding: 0.75rem 1rem; }
            .logo { font-size: 1rem; }
            .status { font-size: 0.65rem; padding: 0.1rem 0.4rem; }
            .badge { font-size: 0.6rem; }
            .device-tag, .method, .path { font-size: 0.75rem; }
        }

        .btn-clear {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .btn-clear:hover {
            background: var(--error);
            color: white;
        }

        .btn-detail {
            background: rgba(56, 189, 248, 0.1);
            color: var(--accent);
            border: 1px solid rgba(56, 189, 248, 0.2);
            padding: 0.3rem 0.6rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            line-height: 1;
            white-space: nowrap;
            text-decoration: none;
        }

        .btn-detail:hover {
            background: var(--accent);
            color: var(--bg);
        }

        .btn-detail svg {
            flex-shrink: 0;
        }

        /* Collapsible sections for Request/Response data */
        .collapsible-section {
            margin-top: 1.25rem;
        }

        .collapsible-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            padding: 0.4rem 0.75rem;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 6px;
            border: 1px solid var(--border);
            margin-bottom: 0.5rem;
            transition: all 0.2s;
            user-select: none;
        }

        .collapsible-header:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--accent);
        }

        .collapsible-header label {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 0;
            cursor: pointer;
            pointer-events: none;
        }

        .collapsible-icon {
            color: var(--text-muted);
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
        }

        .collapsible-section.collapsed .collapsible-icon {
            transform: rotate(-90deg);
        }

        .collapsible-section.collapsed .detail-value {
            display: none;
        }

        .toggle-view-btn, .wrap-toggle {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            color: var(--text-muted);
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.65rem;
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.2s;
            line-height: 1;
            white-space: nowrap;
        }

        .toggle-view-btn:hover, .wrap-toggle:hover {
            background: var(--accent);
            color: white;
            border-color: var(--accent);
        }

        .toggle-view-btn.active, .wrap-toggle.active {
            background: rgba(56, 189, 248, 0.15);
            color: var(--accent);
            border-color: var(--accent);
        }

        .detail-value.wrapped {
            white-space: pre-wrap !important;
            word-break: break-all;
        }

        /* Filter System Styles */
        .filter-bar {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .search-container {
            flex: 1;
            min-width: 250px;
            position: relative;
        }

        .search-input {
            width: 100%;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem 0.6rem 2.5rem;
            color: var(--text);
            font-family: inherit;
            font-size: 0.85rem;
            outline: none;
            transition: all 0.2s;
        }

        .search-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 0.85rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }

        .filter-group {
            display: flex;
            gap: 0.4rem;
            background: rgba(30, 41, 59, 0.5);
            padding: 0.25rem;
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .filter-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 0.35rem 0.75rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }

        .filter-btn:hover {
            color: var(--text);
            background: rgba(255, 255, 255, 0.05);
        }

        .filter-btn.active {
            background: var(--accent);
            color: var(--bg);
        }

        .filter-btn.active.error {
            background: var(--error);
            color: white;
        }

        .filter-btn.active.success {
            background: var(--response);
            color: white;
        }

        .model-select {
            background: var(--card-bg);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 0.5rem 0.75rem;
            border-radius: 8px;
            font-size: 0.75rem;
            font-family: inherit;
            outline: none;
            cursor: pointer;
        }

        .log-entry.filtered-out {
            display: none;
        }
    </style>
</head>
<body>
    <header>
        <div class="logo"><span>&lambda;</span> {{gatewayName}}</div>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <button class="btn-clear" onclick="clearLogs()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                Clear Logs
            </button>
            <div class="status">
                <div class="status-dot"></div>
                Live Monitoring
            </div>
        </div>
    </header>

    <main>
        <div class="filter-bar">
            <div class="search-container">
                <span class="search-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </span>
                <input type="text" id="log-search" class="search-input" placeholder="Search paths, models, content..." oninput="handleFilterChange()">
            </div>
            
            <div class="filter-group">
                <button class="filter-btn active" data-filter="all" onclick="setFilter('status', 'all')">All</button>
                <button class="filter-btn success" data-filter="success" onclick="setFilter('status', 'success')">Success</button>
                <button class="filter-btn error" data-filter="error" onclick="setFilter('status', 'error')">Errors</button>
            </div>

            <div class="filter-group">
                <button class="filter-btn active" data-filter="all-methods" onclick="setFilter('method', 'all')">All Methods</button>
                <button class="filter-btn" data-filter="POST" onclick="setFilter('method', 'POST')">POST</button>
                <button class="filter-btn" data-filter="GET" onclick="setFilter('method', 'GET')">GET</button>
            </div>

            <select id="model-filter" class="model-select" onchange="handleFilterChange()">
                <option value="all">All Models</option>
            </select>
        </div>

        <div class="stats-summary">
            <div>Requests: <span id="stat-requests">0</span></div>
            <div>Avg Latency: <span id="stat-latency">0ms</span></div>
            <div>Tokens (In/Out): <span id="stat-tokens">0 / 0</span></div>
        </div>

        <div class="scroll-area">
            <div id="log-container" class="log-container">
                <!-- Logs will appear here -->
            </div>
        </div>
    </main>

    <script>
        async function clearLogs() {
            const confirmation = prompt('Type "clear" to confirm clearing all logs:');
            if (confirmation === 'clear') {
                try {
                    const response = await fetch('/logs/clear', { method: 'POST' });
                    if (response.ok) {
                        logContainer.innerHTML = '';
                        stats.requests = 0;
                        stats.totalLatency = 0;
                        stats.inTokens = 0;
                        stats.outTokens = 0;
                        stats.responses = 0;
                        updateStats();
                    } else {
                        alert('Failed to clear logs on server');
                    }
                } catch (err) {
                    console.error('Error clearing logs:', err);
                    alert('Error clearing logs');
                }
            }
        }

        const logContainer = document.getElementById('log-container');
        const stats = {
            requests: 0,
            totalLatency: 0,
            inTokens: 0,
            outTokens: 0,
            responses: 0
        };

        const activeFilters = {
            search: '',
            status: 'all',
            method: 'all',
            model: 'all'
        };

        const knownModels = new Set();

        function setFilter(type, value) {
            activeFilters[type] = value;
            
            // Update UI buttons
            if (type === 'status') {
                document.querySelectorAll('[data-filter="all"], [data-filter="success"], [data-filter="error"]').forEach(btn => {
                    btn.classList.toggle('active', btn.getAttribute('data-filter') === value);
                });
            } else if (type === 'method') {
                document.querySelectorAll('[data-filter="all-methods"], [data-filter="POST"], [data-filter="GET"]').forEach(btn => {
                    const filterVal = btn.getAttribute('data-filter') === 'all-methods' ? 'all' : btn.getAttribute('data-filter');
                    btn.classList.toggle('active', filterVal === value);
                });
            }
            
            handleFilterChange();
        }

        function handleFilterChange() {
            activeFilters.search = document.getElementById('log-search').value.toLowerCase();
            activeFilters.model = document.getElementById('model-filter').value;
            applyFilters();
        }

        function applyFilters() {
            const entries = logContainer.querySelectorAll('.log-entry');
            entries.forEach(entry => {
                const log = entry._log;
                if (!log) return;

                let visible = true;

                // Status filter
                if (activeFilters.status === 'success') {
                    if (log.statusCode && log.statusCode >= 400) visible = false;
                } else if (activeFilters.status === 'error') {
                    if (!log.statusCode || log.statusCode < 400) visible = false;
                }

                // Method filter
                if (visible && activeFilters.method !== 'all') {
                    if (log.method !== activeFilters.method) visible = false;
                }

                // Model filter
                if (visible && activeFilters.model !== 'all') {
                    if (log.model !== activeFilters.model) visible = false;
                }

                // Search filter
                if (visible && activeFilters.search) {
                    const searchStr = activeFilters.search;
                    const content = [
                        log.path,
                        log.model,
                        log.userAgent,
                        log.id,
                        typeof log.body === 'string' ? log.body : JSON.stringify(log.body),
                        typeof log.response === 'string' ? log.response : JSON.stringify(log.response)
                    ].join(' ').toLowerCase();
                    
                    if (!content.includes(searchStr)) visible = false;
                }

                entry.classList.toggle('filtered-out', !visible);
            });
        }

        function updateStats() {
            document.getElementById('stat-requests').textContent = stats.requests.toLocaleString();
            const avgLatency = stats.responses > 0 ? Math.round(stats.totalLatency / stats.responses) : 0;
            document.getElementById('stat-latency').textContent = formatDuration(avgLatency);
            document.getElementById('stat-tokens').textContent = stats.inTokens.toLocaleString() + ' / ' + stats.outTokens.toLocaleString();
        }

        function formatDuration(ms) {
            if (ms < 1000) return ms + 'ms';
            return (ms / 1000).toFixed(2) + 's';
        }
        
        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            if (!bytes) return 'N/A';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function getFriendlyName(ua, id) {
            if (!ua || ua === 'Unknown') return null;
            
            const match = ua.match(/^([^/]+)\//) || ua.match(/^Mozilla\/5\.0 \(([^;)]+)/);
            if (match && match[1]) {
                const name = match[1].trim();
                if (!['Mozilla', 'AppleWebKit', 'Chrome', 'Safari'].includes(name)) {
                    return name;
                }
            }
            if (ua.includes('Mozilla')) return null;
            return ua.split(' ')[0] || null;
        }

        function parseStream(raw) {
            if (!raw) return '';
            try {
                return raw.split('\n')
                    .map(line => {
                        const l = line.trim();
                        if (!l) return '';
                        // Handle SSE format "data: {...}" or raw JSON
                        const sseMatch = l.match(/^data:\s*(.*)$/);
                        const jsonPart = sseMatch ? sseMatch[1] : l;
                        try {
                            const parsed = JSON.parse(jsonPart);
                            return parsed.message?.content || 
                                   parsed.response || 
                                   (parsed.choices && parsed.choices[0]?.delta?.content) || 
                                   '';
                        } catch (e) {
                            return '';
                        }
                    }).join('');
            } catch (e) {
                return raw;
            }
        }



        const countedRequests = new Set();
        const countedResponses = new Set();

        function createLogEntry(log) {
            let entry = document.getElementById(`log-${log.id}`);
            const isNew = !entry;
            const wasExpanded = !isNew && entry.classList.contains('expanded');
            
            // Temporary variable to calculate collapsed state before re-render
            const currentId = log.id;
            const wasReqCollapsed = !isNew && entry.querySelector(`#req-section-${currentId}`)?.classList.contains('collapsed');
            const wasResCollapsed = !isNew && entry.querySelector(`#res-section-${currentId}`)?.classList.contains('collapsed');
            
            if (isNew) {
                entry = document.createElement('div');
                entry.id = `log-${log.id}`;
                entry.className = 'log-entry';
                entry._log = {};
            }

            // Merge log data, skipping nulls to preserve existing data (like request body)
            for (const [key, value] of Object.entries(log)) {
                if (value !== null && value !== undefined) {
                    entry._log[key] = value;
                }
            }
            
            const currentLog = entry._log;
            const isStreaming = currentLog.type === 'streaming';
            const isResponse = currentLog.type === 'response' || currentLog.statusCode !== undefined;
            const isError = currentLog.statusCode >= 400;
            
            let badgeClass = 'badge-pending';
            let badgeText = 'Pending';
            
            if (isStreaming) {
                badgeClass = 'badge-streaming';
                badgeText = 'Streaming';
            } else if (isResponse) {
                if (isError) {
                    badgeClass = 'badge-failed';
                    badgeText = 'Failed';
                } else {
                    badgeClass = 'badge-completed';
                    badgeText = 'Completed';
                }
            }

            const deviceName = getFriendlyName(currentLog.userAgent, currentLog.id);
            const headerLabel = deviceName || `[${currentLog.id}]`;

            entry.innerHTML = `
                <div class="log-header" onclick="this.parentElement.classList.toggle('expanded')">
                    <div class="log-info">
                        <span class="badge ${badgeClass}">${badgeText}</span>
                        <span class="device-tag">${headerLabel}</span>
                        <span class="method">${currentLog.method}</span>
                        <span class="path">${currentLog.path}</span>
                    </div>
                    <div class="time" style="display: flex; align-items: center; gap: 0.75rem;">
                        ${currentLog.statusCode ? `<span class="${isError ? 'badge-error' : 'badge-response'}" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 700;">${currentLog.statusCode}</span> • ` : ''}
                        ${isResponse && currentLog.duration_ms ? `<span>${formatDuration(currentLog.duration_ms)}</span> • ` : ''}
                        ${isStreaming ? '<span style="color: #a855f7; font-size: 0.7rem; font-weight: 600;">ACTIVE</span> • ' : ''}
                        ${new Date(currentLog.timestamp).toLocaleTimeString()}
                        <a href="/dashboard/${currentLog.id}" onclick="event.stopPropagation()" class="btn-detail">
                            Details
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        </a>
                    </div>
                </div>
                <div class="log-details">
                    <div class="details-grid">
                        ${currentLog.model ? `
                        <div class="detail-item">
                            <label>Model</label>
                            <div class="detail-value">${currentLog.model}</div>
                        </div>` : ''}
                        ${currentLog.userAgent ? `
                        <div class="detail-item">
                            <label>Device / App</label>
                            <div class="detail-value">${currentLog.userAgent}</div>
                        </div>` : ''}
                        ${currentLog.input_tokens ? `
                        <div class="detail-item">
                            <label>Input Tokens</label>
                            <div class="detail-value">${currentLog.input_tokens.toLocaleString()}</div>
                        </div>` : ''}
                        ${currentLog.output_tokens ? `
                        <div class="detail-item">
                            <label>Output Tokens</label>
                            <div class="detail-value">${currentLog.output_tokens.toLocaleString()}</div>
                        </div>` : ''}
                        ${currentLog.statusCode ? `
                        <div class="detail-item">
                            <label>Status</label>
                            <div class="detail-value ${isError ? 'badge-error' : ''}" style="display:inline-block">${currentLog.statusCode}</div>
                        </div>` : ''}
                        ${currentLog.request_size ? `
                        <div class="detail-item">
                            <label>Request Size</label>
                            <div class="detail-value">${formatBytes(currentLog.request_size)}</div>
                        </div>` : ''}
                        ${currentLog.response_size ? `
                        <div class="detail-item">
                            <label>Response Size</label>
                            <div class="detail-value">${formatBytes(currentLog.response_size)}</div>
                        </div>` : ''}
                    </div>
                    <div class="collapsible-section ${wasReqCollapsed ? 'collapsed' : ''}" id="req-section-${currentLog.id}">
                        <div class="collapsible-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <label>Request Body</label>
                            <span class="collapsible-icon">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </span>
                        </div>
                        <div class="detail-value" id="request-data-${currentLog.id}"></div>
                    </div>
                    ${(currentLog.response || currentLog.isStream || currentLog.type === 'streaming') ? `
                    <div class="collapsible-section ${wasResCollapsed ? 'collapsed' : ''}" id="res-section-${currentLog.id}">
                        <div class="collapsible-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <label>Response Data</label>
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                ${(currentLog.isStream || currentLog.type === 'streaming') ? `<button id="stream-toggle-${currentLog.id}" class="toggle-view-btn" onclick="event.stopPropagation(); toggleStreamView('${currentLog.id}')">${entry._viewMode === 'clean' ? 'Raw View' : 'Clean View'}</button>` : ''}
                                <button id="wrap-toggle-${currentLog.id}" class="wrap-toggle" onclick="event.stopPropagation(); toggleWrap(this, 'response-data-${currentLog.id}')">Wrap Text</button>
                                <span class="collapsible-icon">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                </span>
                            </div>
                        </div>
                        <div class="detail-value" id="response-data-${currentLog.id}"></div>
                    </div>` : ''}
                </div>
            `;

            if (wasExpanded) entry.classList.add('expanded');

            // Render raw data
            const requestContainer = entry.querySelector(`#request-data-${currentLog.id}`);
            const requestBody = currentLog.body || 'No data';
            requestContainer.textContent = typeof requestBody === 'object' ? JSON.stringify(requestBody, null, 2) : requestBody;

            if (currentLog.response) {
                const responseContainer = entry.querySelector(`#response-data-${currentLog.id}`);
                const isClean = entry._viewMode === 'clean';
                if (currentLog.isStream && isClean) {
                    responseContainer.textContent = parseStream(currentLog.response);
                } else {
                    responseContainer.textContent = typeof currentLog.response === 'object' ? JSON.stringify(currentLog.response, null, 2) : currentLog.response;
                }
            }

            if (isNew) {
                if (logContainer.firstChild) {
                    logContainer.insertBefore(entry, logContainer.firstChild);
                } else {
                    logContainer.appendChild(entry);
                }
            }

            // Update stats
            if ((currentLog.type === 'request' || currentLog.body) && !countedRequests.has(currentLog.id)) {
                stats.requests++;
                countedRequests.add(currentLog.id);
                if (currentLog.input_tokens) stats.inTokens += currentLog.input_tokens;
            }
            if ((currentLog.type === 'response' || currentLog.statusCode) && !countedResponses.has(currentLog.id)) {
                stats.responses++;
                countedResponses.add(currentLog.id);
                if (currentLog.duration_ms) stats.totalLatency += currentLog.duration_ms;
                if (currentLog.output_tokens) stats.outTokens += currentLog.output_tokens;
            }
            updateStats();

            // Keep only last 100 in DOM
            if (logContainer.children.length > 100) {
                logContainer.lastChild.remove();
            }

            // Update known models
            if (currentLog.model && !knownModels.has(currentLog.model)) {
                knownModels.add(currentLog.model);
                const modelFilter = document.getElementById('model-filter');
                const option = document.createElement('option');
                option.value = currentLog.model;
                option.textContent = currentLog.model;
                modelFilter.appendChild(option);
            }

            // Apply filters to new entry
            applyFilters();
        }

        const evtSource = new EventSource("/logs/stream");
        evtSource.onmessage = (event) => {
            const data = JSON.parse(event.data);
            if (Array.isArray(data)) {
                data.forEach(createLogEntry);
            } else {
                createLogEntry(data);
            }
        };

        evtSource.onerror = (err) => {
            console.error("EventSource failed:", err);
            document.querySelector('.status').style.color = 'var(--error)';
            document.querySelector('.status').style.background = 'rgba(239, 68, 68, 0.1)';
            document.querySelector('.status-dot').style.backgroundColor = 'var(--error)';
            document.querySelector('.status-dot').style.boxShadow = '0 0 12px var(--error)';
        };
        function toggleWrap(btn, targetId) {
            const el = document.getElementById(targetId);
            if (!el) return;
            const isWrapped = el.classList.toggle('wrapped');
            btn.classList.toggle('active', isWrapped);
            btn.textContent = isWrapped ? 'Unwrap Text' : 'Wrap Text';
        }

        function toggleStreamView(id) {
            const entry = document.getElementById(`log-${id}`);
            if (!entry) return;
            
            entry._viewMode = entry._viewMode === 'clean' ? 'raw' : 'clean';
            createLogEntry(entry._log);
        }
    </script>
</body>
</html>
